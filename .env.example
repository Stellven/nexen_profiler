# Gemini credentials
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=

# Core runtime config
DATA_DIR=./data
DB_URL=sqlite:///user_profiler.db
USER_ID=default_user
PROFILE_LANG=en

# Gemini model config
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_BATCH=100
EMBEDDING_DIM=3072

# Output and prototype overrides
PROFILE_MD_PATH=./outputs
# ROLES_PATH=./prototypes/roles.yml

# Console behavior
NO_PROGRESS=0
